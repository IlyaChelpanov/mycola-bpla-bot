# Provider: openai | groq | anthropic
LLM_PROVIDER=groq

TELEGRAM_TOKEN=

# Fill the key for whichever provider you picked above.
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Model must match the provider:
#   groq:      meta-llama/llama-4-scout-17b-16e-instruct  (strong, big context)
#              llama-3.3-70b-versatile
#   openai:    gpt-4o-mini
#   anthropic: claude-haiku-4-5
MODEL=meta-llama/llama-4-scout-17b-16e-instruct

SYSTEM_PROMPT=Отвечай кратко и по делу на русском языке.
MAX_TOKENS=500
RATE_LIMIT_SECONDS=5

# Owner (for /prompt /model /update). Leave 0 and run /claim once in chat.
OWNER_ID=0

# Message log + summary feature
DB_PATH=bot.db
SUMMARY_COUNT=200
HISTORY_KEEP=500

# Vision: max images processed per day (across all chats) to cap token burn
IMAGE_DAILY_LIMIT=50

# Web search: let the bot look things up online (weather, news, prices, etc.)
# via Tavily function-calling. Needs a provider that supports tool calls
# (openai or groq). Get a free key at https://tavily.com (tvly-...).
# This is the default; the owner can flip it at runtime with /websearch on|off.
# A key is always required for search to actually run.
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=
