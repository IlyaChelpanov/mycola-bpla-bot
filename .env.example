# Provider: openai | groq | anthropic
LLM_PROVIDER=groq

TELEGRAM_TOKEN=

# Fill the key for whichever provider you picked above.
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Model must match the provider:
#   groq:      llama-3.3-70b-versatile
#   openai:    gpt-4o-mini
#   anthropic: claude-haiku-4-5
MODEL=llama-3.3-70b-versatile

SYSTEM_PROMPT=Ты — дружелюбный помощник в групповом чате. Отвечай кратко и по делу на русском языке.
MAX_TOKENS=500
RATE_LIMIT_SECONDS=5
